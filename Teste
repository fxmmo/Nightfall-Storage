local HighlightRegistry = {}
local function applyHighlight(options)
    options = options or {}

    local target = options.target
    if not target then return end

    local name = options.name or "Highlight"
    local color = options.color or Color3.new(1, 1, 1)
    local group = options.group or "Default"

    HighlightRegistry[group] = HighlightRegistry[group] or {}

    local h = target:FindFirstChild(name)
    if not h then
        h = Instance.new("Highlight")
        h.Name = name
        h.Parent = target
        table.insert(HighlightRegistry[group], h)
    end

    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = options.fillTransparency or Settings.Visual.espTransparency or 0.8
    h.OutlineTransparency = options.outlineTransparency or 0
    h.Enabled = true
    h.Adornee = target
    return h
end

local function clearHighlight(group)
    local reg = HighlightRegistry[group]
    if not reg then return end

    for i = #reg, 1, -1 do
        local h = reg[i]
        if h and h.Parent then
            h:Destroy()
        end
        reg[i] = nil
    end
end

function randomString(length)
    local charset = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local result = ""
    for i = 1, length do
        result = result .. string.sub(charset, math.random(1, #charset), math.random(1, #charset))
    end
    return result
end

local function Notify(options)
    options = options or {}

    local title = options.Title or "Night Helper"
    local content = options.Content or "Without Content"
    local duration = options.Duration or 2
    local icon = options.Icon or "solar:bell-bold"
    local soundType = options.SoundType

    local function PlayNotifySound(soundType)
        local sound = Instance.new("Sound")
        local sounds = {
            default = "rbxassetid://18886652611",
            error = "rbxassetid://17208372272"
        }

        sound.SoundId = sounds[soundType] or sounds.default
        sound.Volume = Settings.Hub.NotifyVolume
        sound.Parent = SoundService
        sound:Play()

        sound.Ended:Connect(function()
            sound:Destroy()
        end)
    end

    if Settings.Hub.EnabledNotifications then
        PlayNotifySound(soundType)
        Wind:Notify({
            Title = title,
            Content = content,
            Duration = duration,
            Icon = icon
        })
    end
end

