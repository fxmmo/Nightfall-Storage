local CONFIG_FOLDER = "Nightfall"
local CONFIG_FILE = CONFIG_FOLDER .. "/Settings/Flee-The-Facility/config.json"

local function ensureFolder()
    if isfolder and makefolder then
        if not isfolder(CONFIG_FOLDER) then
            makefolder(CONFIG_FOLDER)
        end
    end
end

local function serializeSettings()
    return {
        Player = Settings.Player,
        Auto = Settings.Auto,
        Visual = Settings.Visual,
        Combat = Settings.Combat,
        Hub = Settings.Hub,
        Misc = Settings.Misc,
    }
end

local function applySettings(data)
    if type(data) ~= "table" then return end

    for sectionName, sectionData in pairs(data) do
        if type(sectionData) == "table" and type(Settings[sectionName]) == "table" then
            for key, value in pairs(sectionData) do
                Settings[sectionName][key] = value
            end
        end
    end
end

local function saveConfig()
    ensureFolder()

    local data = serializeSettings()
    local encoded = HttpService:JSONEncode(data)

    if writefile then
        writefile(CONFIG_FILE, encoded)
        return true
    end

    return false
end

local function loadConfig()
    if isfile and isfile(CONFIG_FILE) and readfile then
        local success, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(CONFIG_FILE))
        end)

        if success and type(decoded) == "table" then
            applySettings(decoded)
            return true
        end
    end

    return false
end

